# Copy to .env and fill in. NEVER commit .env.
#
# The Ed25519 private key used to sign licenses. Generate with `npm run keygen`,
# then paste the PRIVATE key PEM here as a single line with \n escapes, e.g.
#   LICENSE_PRIVATE_KEY="***REMOVED***\n"
# This value is the crown jewel — whoever holds it can mint licenses. It exists
# only here on the server, never in git and never in the shipped app.
LICENSE_PRIVATE_KEY=

# HTTP port the Node service listens on (Caddy proxies to this).
PORT=3000

# Where the SQLite database file lives. In Docker this is a mounted volume.
DB_PATH=./data/pos-platform.db

# The public domain Caddy serves and requests TLS for (used by docker-compose).
DOMAIN=api.example.com
