node_modules/
*.log

# Secrets — never commit key material or env files
.env
.env.*
!.env.example
*.env
*.pem
keys/

# Update feed artifacts (installers uploaded by the app's publish script) — only the
# directory itself is tracked so the bind mounts always have a target
updates/*
!updates/.gitkeep

# Local database + backups
data/
*.db
*.db-journal
*.db-wal
*.db-shm
backups/

# Terraform — state can contain sensitive attributes; never commit it or real tfvars
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log

# Secrets
.env
.env.*
!.env*.example
*.pem
*.key
